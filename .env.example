# LiveKit (required)
# Sign up free at https://livekit.io/cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram — Speech-to-Text (required)
DEEPGRAM_API_KEY=

# ElevenLabs — Text-to-Speech (required)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Rachel
ELEVENLABS_MODEL=eleven_turbo_v2_5

# LLM provider: openai | anthropic | gemini (default: openai)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# System prompt for the bot (optional)
SYSTEM_PROMPT=You are a helpful AI assistant on a video call. Be concise and conversational.

# LiveAvatar — talking avatar (optional)
# Get your API key and create a custom avatar at https://www.liveavatar.com
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=

# Twilio — outbound PSTN calls (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_URL=
